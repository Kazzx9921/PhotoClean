        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Funciona 100 %% sin conexión. No se envía nada a ningún servidor.\n\nCódigo abierto — clónalo desde GitHub para instalarlo en tu propio dispositivo."
          }
