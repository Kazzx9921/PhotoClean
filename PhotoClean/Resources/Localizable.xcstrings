    "Photos stay in iOS Recently Deleted for 30 days. Empty them from the system Photos app to free space immediately.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las fotos permanecen 30 días en «Eliminadas recientemente» de iOS. Vacíalas desde la app Fotos del sistema para liberar espacio de inmediato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真は iOS の「最近削除した項目」に 30 日間保持されます。システムの写真アプリから空にすると、すぐに容量が解放されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "照片会在 iOS「最近删除」保留 30 天。到系统相册清空才会立刻释放空间。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "照片會在 iOS「最近刪除」保留 30 天。到系統相簿清空才會立刻釋放空間。"
          }
        }
      }
