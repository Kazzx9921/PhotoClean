    "%lld photos will be moved to iOS Recently Deleted. About %@ will be freed.": {
      "extractionState": "stale",
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se moverán %lld fotos a «Eliminadas recientemente» de iOS. Se liberarán aproximadamente %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 枚の写真が iOS の「最近削除した項目」に移動されます。約 %@ が解放されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将移动 %lld 张照片至 iOS「最近删除」,约释放 %@。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將移動 %lld 張照片至 iOS「最近刪除」,約釋放 %@。"
          }
        }
      }
    },
